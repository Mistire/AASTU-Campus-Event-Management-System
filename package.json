{
    "name": "aastu-campus-event-management-system",
    "version": "0.0.1",
    "description": "AASTU Campus Event Management System - Monorepo Root",
    "private": true,
    "workspaces": [
        "apps/*"
    ],
    "scripts": {
        "dev": "npm run start:dev --prefix apps/api",
        "start": "npm run start --prefix apps/api",
        "start:dev": "npm run start:dev --prefix apps/api",
        "start:debug": "npm run start:debug --prefix apps/api",
        "start:prod": "npm run start:prod --prefix apps/api",
        "build": "npm run build --prefix apps/api",
        "lint": "npm run lint --prefix apps/api",
        "format": "npm run format --prefix apps/api",
        "test": "npm run test --prefix apps/api",
        "test:watch": "npm run test:watch --prefix apps/api",
        "test:cov": "npm run test:cov --prefix apps/api",
        "test:e2e": "npm run test:e2e --prefix apps/api",
        "prisma:generate": "npm run prisma:generate --prefix apps/api",
        "prisma:migrate": "npm run prisma:migrate --prefix apps/api",
        "prisma:deploy": "npm run prisma:deploy --prefix apps/api",
        "prisma:studio": "npm run prisma:studio --prefix apps/api",
        "prisma:reset": "npm run prisma:reset --prefix apps/api",
        "docker:up": "docker compose up -d",
        "docker:up:build": "docker compose up -d --build",
        "docker:down": "docker compose down",
        "docker:down:volumes": "docker compose down -v",
        "docker:logs": "docker compose logs -f",
        "docker:logs:api": "docker compose logs -f api",
        "docker:restart": "docker compose down && docker compose up -d --build",
        "docker:restart:api": "docker compose restart api",
        "docker:ps": "docker compose ps",
        "db:up": "docker compose up postgres -d",
        "db:rm": "docker compose rm postgres -s -f -v",
        "db:reset": "npm run db:rm && npm run db:up",
        "db:sync": "npm run prisma:generate --prefix apps/api && npm run prisma:deploy --prefix apps/api && npm run script_roles --prefix apps/api && npm run script_users --prefix apps/api",
        "db:sync:docker": "docker compose exec api sh -c 'npx prisma generate && npx prisma db push && npm run script_roles && npm run script_users'"
    },
    "dependencies": {
        "class-validator": "^0.15.1"
    }
}
