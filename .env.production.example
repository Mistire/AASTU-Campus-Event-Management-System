# Copy values into GitHub Actions secrets and/or /app/cems/.env on EC2.
# Public app URL: http://YOUR_EC2_IP  (port 80 via nginx — do NOT use :3001 from browser)

# ─── Database ────────────────────────────────────────────
DATABASE_URL=postgresql://cems:cems_secret@postgres:5432/cems_db?schema=public
POSTGRES_USER=cems
POSTGRES_PASSWORD=cems_secret
POSTGRES_DB=cems_db

# ─── Redis ───────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ─── JWT ─────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret
JWT_REFRESH_SECRET=your-jwt-refresh-secret
JWT_EXPIRATION=1h
JWT_REFRESH_EXPIRATION=7d

# ─── Application ─────────────────────────────────────────
PORT=4000
NODE_ENV=production
BACKEND_URL=http://api:4000
FRONTEND_URL=http://YOUR_EC2_IP
PRISMA_LOG_QUERIES=false

# ─── Email (SMTP) ────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=your-email@gmail.com

EMAIL_VERIFICATION_TOKEN_TTL=60
RESET_TOKEN_TTL_MINUTES=30

# ─── Seed (optional manual scripts) ──────────────────────
SEED_SUPERUSER_EMAIL=admin@example.com
SEED_SUPERUSER_PASSWORD=password123
SEED_SUPERUSER_FULL_NAME=Admin User

# ─── Cloudinary (baked into web image at build time) ─────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your_upload_preset

# ─── Web (public URLs — baked into web image at build) ───
NEXT_PUBLIC_API_URL=http://YOUR_EC2_IP
NEXT_PUBLIC_SOCKET_URL=http://YOUR_EC2_IP

# ─── Telegram ────────────────────────────────────────────
# Leave TELEGRAM_WEBHOOK_URL empty on HTTP-only EC2 — bot uses polling instead.
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_BOT_USERNAME=your_bot_username
TELEGRAM_CHANNEL_ID=@your_channel
TELEGRAM_WEBHOOK_URL=
