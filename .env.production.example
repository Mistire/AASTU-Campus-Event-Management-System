# Production .env for EC2 (/app/cems/.env) and GitHub Actions secrets.
# Open the app at http://YOUR_EC2_IP  (port 80 — NOT :3001)

# ─── Database ────────────────────────────────────────────
DATABASE_URL=postgresql://cems:cems_secret@postgres:5432/cems_db?schema=public
POSTGRES_USER=cems
POSTGRES_PASSWORD=cems_secret
POSTGRES_DB=cems_db

# ─── Redis ───────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ─── JWT ─────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret
JWT_REFRESH_SECRET=your-jwt-refresh-secret
JWT_EXPIRATION=1h
JWT_REFRESH_EXPIRATION=7d

# ─── Application ─────────────────────────────────────────
PORT=4000
NODE_ENV=production
BACKEND_URL=http://api:4000
FRONTEND_URL=http://13.60.27.84
PRISMA_LOG_QUERIES=false

# ─── Email (SMTP) ────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=your-email@gmail.com

EMAIL_VERIFICATION_TOKEN_TTL=60
RESET_TOKEN_TTL_MINUTES=30

# ─── Seed (optional manual scripts) ──────────────────────
SEED_SUPERUSER_EMAIL=nasifayc11@gmail.com
SEED_SUPERUSER_PASSWORD=123456
SEED_SUPERUSER_FULL_NAME=Test Admin User

# ─── Cloudinary (baked into web image at build time) ─────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=drwczqmog
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=quwz3ubp

# ─── Web (public URLs — baked into web image at build) ───
NEXT_PUBLIC_API_URL=http://13.60.27.84
NEXT_PUBLIC_SOCKET_URL=http://13.60.27.84

# ─── Telegram ────────────────────────────────────────────
# Leave TELEGRAM_WEBHOOK_URL empty on HTTP-only EC2 — bot uses polling.
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_BOT_USERNAME=aastu_cems_bot
TELEGRAM_CHANNEL_ID=@aastu_cems
TELEGRAM_WEBHOOK_URL=
