# ─── Database ────────────────────────────────────────────
DATABASE_URL=postgresql://cems:cems_secret@localhost:5432/cems_db
POSTGRES_USER=cems
POSTGRES_PASSWORD=cems_secret
POSTGRES_DB=cems_db

# ─── Redis ───────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── JWT ─────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-strong-random-secret
JWT_REFRESH_SECRET=change-me-to-a-strong-random-secret
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ─── Application ─────────────────────────────────────────
PORT=4000
NODE_ENV=development
BACKEND_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3001
PRISMA_LOG_QUERIES=false

# ─── Email (SMTP) ────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com

# ─── Security/Tokens ─────────────────────────────────────
EMAIL_VERIFICATION_TOKEN_TTL=60
RESET_TOKEN_TTL_MINUTES=30

# ─── Seed Data ───────────────────────────────────────────
SEED_SUPERUSER_EMAIL=admin@example.com
SEED_SUPERUSER_PASSWORD=password123
superFullName=Admin User

# ─── Cloudinary ──────────────────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your_upload_preset

# ─── Telegram Bot ────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_BOT_USERNAME=your_bot_username
# TELEGRAM_WEBHOOK_URL=https://your-domain.com/api/telegram/webhook

# ─── Web App (Frontend) ──────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000

# ─── ML Service ──────────────────────────────────────────
ML_SERVICE_URL=http://ml-service:8000
