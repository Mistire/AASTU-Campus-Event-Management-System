generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Role {
  id          String           @id @default(uuid()) @db.Uuid
  roleName    String           @unique @map("role_name") @db.VarChar
  description String?
  createdAt   DateTime         @default(now()) @map("created_at")
  permissions RolePermission[]
  users       User[]

  @@map("roles")
}

model Permission {
  id          String           @id @default(uuid()) @db.Uuid
  name        String           @unique @db.VarChar
  description String?
  createdAt   DateTime         @default(now()) @map("created_at")
  roles       RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(uuid()) @db.Uuid
  roleId       String     @map("role_id") @db.Uuid
  permissionId String     @map("permission_id") @db.Uuid
  createdAt    DateTime   @default(now()) @map("created_at")
  permission   Permission @relation(fields: [permissionId], references: [id])
  role         Role       @relation(fields: [roleId], references: [id])

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model User {
  id                  String                    @id @default(uuid()) @db.Uuid
  fullName            String                    @map("full_name") @db.VarChar
  email               String                    @unique @db.VarChar
  passwordHash        String                    @map("password_hash") @db.VarChar
  roleId              String                    @map("role_id") @db.Uuid
  departmentId        String?                   @map("department_id") @db.Uuid
  phone               String?                   @db.VarChar
  profileImage        String?                   @map("profile_image") @db.VarChar
  createdAt           DateTime                  @default(now()) @map("created_at")
  updatedAt           DateTime                  @updatedAt @map("updated_at")
  emailVerifiedAt     DateTime?                 @map("email_verified_at")
  isEmailVerified     Boolean                   @default(false) @map("is_email_verified")
  passwordChangedAt   DateTime?                 @map("password_changed_at")
  studentId           String?                   @unique @map("student_id") @db.VarChar
  academicProgram     String?                   @map("academic_program") @db.VarChar
  isCampusIdVerified  Boolean                   @default(false) @map("is_campus_id_verified")
  campusIdVerifiedAt  DateTime?                 @map("campus_id_verified_at")
  announcements       Announcements[]
  attendance          Attendance[]
  auditLogs           AuditLogs[]
  authSessions        AuthSession[]
  sentInvites         EventInvites[]            @relation("InviterUser")
  receivedInvites     EventInvites[]            @relation("InvitedUser")
  eventOrganizers     EventOrganizers[]
  eventWaitlist       EventWaitlist[]
  createdEvents       Event[]                   @relation("EventCreator")
  feedback            Feedback[]
  judgedEvents        Judges[]
  notifications       Notification[]
  oneTimeTokens       OneTimeToken[]
  registrations       Registration[]
  supportMessages     SupportMessage[]
  supportTickets      SupportTicket[]
  teamMembers         TeamMembers[]
  ledTeams            Teams[]
  categoryPreferences UserCategoryPreferences[]
  userInterests       UserInterests[]
  bookmarks           EventBookmark[]
  department          Department?               @relation(fields: [departmentId], references: [id])
  role                Role                      @relation(fields: [roleId], references: [id])

  @@map("users")
}

model UserCategoryPreferences {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  categoryId String   @map("category_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")
  category   Category @relation(fields: [categoryId], references: [id])
  user       User     @relation(fields: [userId], references: [id])

  @@unique([userId, categoryId])
  @@map("user_category_preferences")
}

model AuthSession {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  refreshTokenHash String    @map("refresh_token_hash") @db.VarChar
  userAgent        String?   @map("user_agent") @db.VarChar
  ipAddress        String?   @map("ip_address") @db.VarChar
  isRevoked        Boolean   @default(false) @map("is_revoked")
  expiresAt        DateTime  @map("expires_at")
  revokedAt        DateTime? @map("revoked_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  user             User      @relation(fields: [userId], references: [id])

  @@index([userId, isRevoked])
  @@index([expiresAt])
  @@map("auth_sessions")
}

model OneTimeToken {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  tokenHash String           @map("token_hash") @db.VarChar
  type      OneTimeTokenType
  expiresAt DateTime         @map("expires_at")
  usedAt    DateTime?        @map("used_at")
  createdAt DateTime         @default(now()) @map("created_at")
  user      User             @relation(fields: [userId], references: [id])

  @@index([userId, type, usedAt])
  @@index([expiresAt])
  @@map("one_time_tokens")
}

model Department {
  id      String  @id @default(uuid()) @db.Uuid
  name    String  @db.VarChar
  faculty String? @db.VarChar
  users   User[]

  @@map("departments")
}

model EventStatus {
  id          String  @id @default(uuid()) @db.Uuid
  statusName  String  @unique @map("status_name") @db.VarChar
  description String?
  events      Event[]

  @@map("event_status")
}

model Category {
  id              String                    @id @default(uuid()) @db.Uuid
  name            String                    @db.VarChar
  description     String?
  eventCategories EventCategory[]
  userPreferences UserCategoryPreferences[]

  @@map("categories")
}

model EventCategory {
  eventId    String   @map("event_id") @db.Uuid
  categoryId String   @map("category_id") @db.Uuid
  category   Category @relation(fields: [categoryId], references: [id])
  event      Event    @relation(fields: [eventId], references: [id])

  @@id([eventId, categoryId])
  @@map("event_categories")
}

model Interest {
  id            String          @id @default(uuid()) @db.Uuid
  name          String          @db.VarChar
  description   String?
  userInterests UserInterests[]

  @@map("interests")
}

model Tag {
  id        String      @id @default(uuid()) @db.Uuid
  name      String      @unique @db.VarChar
  eventTags EventTags[]

  @@map("tags")
}

model Venue {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar
  building    String?  @db.VarChar
  roomNumber  String?  @map("room_number") @db.VarChar
  capacity    Int?
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")
  events      Event[]

  @@unique([name, building, roomNumber])
  @@map("venues")
}

model Event {
  id                String            @id @default(uuid()) @db.Uuid
  title             String            @db.VarChar
  description       String?
  statusId          String            @map("status_id") @db.Uuid
  venueId           String            @map("venue_id") @db.Uuid
  startTime         DateTime          @map("start_time")
  endTime           DateTime          @map("end_time")
  capacity          Int
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")
  createdBy         String?           @map("created_by") @db.Uuid
  eventTypeId       String?           @map("event_type_id") @db.Uuid
  requiresApproval  Boolean           @default(false) @map("requires_approval")
  guestLimitPerUser Int?              @map("guest_limit_per_user")
  announcements     Announcements[]
  attendance        Attendance[]
  access            EventAccess[]
  eventCategories   EventCategory[]
  invites           EventInvites[]
  media             EventMedia[]
  organizers        EventOrganizers[]
  sessions          EventSessions[]
  tags              EventTags[]
  waitlist          EventWaitlist[]
  creator           User?             @relation("EventCreator", fields: [createdBy], references: [id])
  eventType         EventType?        @relation(fields: [eventTypeId], references: [id])
  status            EventStatus       @relation(fields: [statusId], references: [id])
  venue             Venue             @relation(fields: [venueId], references: [id])
  feedback          Feedback[]
  formFields        FormFields[]
  hackathons        Hackathons[]
  judges            Judges[]
  registrations     Registration[]
  teams             Teams[]
  bookmarks         EventBookmark[]

  @@map("events")
}

model EventBookmark {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  eventId   String   @map("event_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@map("event_bookmarks")
}

model EventSessions {
  id          String            @id @default(uuid()) @db.Uuid
  eventId     String            @map("event_id") @db.Uuid
  title       String            @db.VarChar
  startTime   DateTime          @map("start_time")
  endTime     DateTime          @map("end_time")
  description String?
  location    String?           @db.VarChar
  sessionType String?           @map("session_type") @db.VarChar
  attendance  Attendance[]
  event       Event             @relation(fields: [eventId], references: [id])
  media       SessionMedia[]
  speakers    SessionSpeakers[]

  @@map("event_sessions")
}

model EventOrganizers {
  id          String    @id @default(uuid()) @db.Uuid
  eventId     String    @map("event_id") @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  role        String?   @db.VarChar
  invitedAt   DateTime  @default(now()) @map("invited_at")
  respondedAt DateTime? @map("responded_at")
  status      String    @default("ACCEPTED") @db.VarChar
  event       Event     @relation(fields: [eventId], references: [id])
  user        User      @relation(fields: [userId], references: [id])

  @@unique([eventId, userId])
  @@map("event_organizers")
}

model AuditLogs {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  action      String   @db.VarChar
  entityType  String   @map("entity_type") @db.VarChar
  entityId    String?  @map("entity_id") @db.Uuid
  details     String?
  createdAt   DateTime @default(now()) @map("created_at")
  afterState  Json?    @map("after_state")
  beforeState Json?    @map("before_state")
  environment String?  @db.VarChar
  ipAddress   String?  @map("ip_address") @db.VarChar
  outcome     String   @default("SUCCESS") @db.VarChar
  role        String?  @db.VarChar
  userAgent   String?  @map("user_agent") @db.VarChar
  user        User     @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model Announcements {
  id        String   @id @default(uuid()) @db.Uuid
  eventId   String   @map("event_id") @db.Uuid
  title     String   @db.VarChar
  message   String
  createdAt DateTime @default(now()) @map("created_at")
  createdBy String   @map("created_by") @db.Uuid
  creator   User     @relation(fields: [createdBy], references: [id])
  event     Event    @relation(fields: [eventId], references: [id])

  @@map("announcements")
}

model EventWaitlist {
  id       String   @id @default(uuid()) @db.Uuid
  userId   String   @map("user_id") @db.Uuid
  eventId  String   @map("event_id") @db.Uuid
  joinedAt DateTime @default(now()) @map("joined_at")
  position Int
  event    Event    @relation(fields: [eventId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@map("event_waitlist")
}

model UserInterests {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  interestId String   @map("interest_id") @db.Uuid
  interest   Interest @relation(fields: [interestId], references: [id])
  user       User     @relation(fields: [userId], references: [id])

  @@map("user_interests")
}

model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  title     String   @db.VarChar
  message   String
  type      String   @db.VarChar
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id])

  @@map("notifications")
}

model Registration {
  id               String             @id @default(uuid()) @db.Uuid
  userId           String             @map("user_id") @db.Uuid
  eventId          String             @map("event_id") @db.Uuid
  registrationDate DateTime           @default(now()) @map("registration_date")
  deletedAt        DateTime?          @map("deleted_at")
  statusId         String             @map("status_id") @db.Uuid
  formResponses    FormResponses[]
  event            Event              @relation(fields: [eventId], references: [id])
  status           RegistrationStatus @relation(fields: [statusId], references: [id])
  user             User               @relation(fields: [userId], references: [id])

  @@map("registrations")
}

model Attendance {
  id          String         @id @default(uuid()) @db.Uuid
  userId      String?        @map("user_id") @db.Uuid
  eventId     String         @map("event_id") @db.Uuid
  sessionId   String?        @map("session_id") @db.Uuid
  checkInTime DateTime       @map("check_in_time")
  qrToken     String         @map("qr_token") @db.VarChar
  inviteId    String?        @map("invite_id") @db.Uuid
  event       Event          @relation(fields: [eventId], references: [id])
  invite      EventInvites?  @relation(fields: [inviteId], references: [id])
  session     EventSessions? @relation(fields: [sessionId], references: [id])
  user        User?          @relation(fields: [userId], references: [id])

  @@map("attendance")
}

model Feedback {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  eventId   String   @map("event_id") @db.Uuid
  rating    Int
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")
  event     Event    @relation(fields: [eventId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@map("feedback")
}

model EventMedia {
  id         String   @id @default(uuid()) @db.Uuid
  eventId    String   @map("event_id") @db.Uuid
  fileUrl    String   @map("file_url") @db.VarChar
  mediaType  String   @map("media_type") @db.VarChar
  uploadedAt DateTime @default(now()) @map("uploaded_at")
  event      Event    @relation(fields: [eventId], references: [id])

  @@map("event_media")
}

model EventTags {
  id      String @id @default(uuid()) @db.Uuid
  eventId String @map("event_id") @db.Uuid
  tagId   String @map("tag_id") @db.Uuid
  event   Event  @relation(fields: [eventId], references: [id])
  tag     Tag    @relation(fields: [tagId], references: [id])

  @@map("event_tags")
}

model EventType {
  id          String  @id @default(uuid()) @db.Uuid
  name        String  @unique @db.VarChar
  description String?
  events      Event[]

  @@map("event_types")
}

model EventAccess {
  id               String  @id @default(uuid()) @db.Uuid
  eventId          String  @map("event_id") @db.Uuid
  accessType       String  @map("access_type") @db.VarChar
  requiresApproval Boolean @map("requires_approval")
  event            Event   @relation(fields: [eventId], references: [id])

  @@map("event_access")
}

model EventInvites {
  id           String       @id @default(uuid()) @db.Uuid
  eventId      String       @map("event_id") @db.Uuid
  userId       String?      @map("user_id") @db.Uuid
  invitedEmail String       @map("invited_email") @db.VarChar
  status       String       @default("PENDING") @db.VarChar
  createdAt    DateTime     @default(now()) @map("created_at")
  invitedBy    String       @map("invited_by") @db.Uuid
  respondedAt  DateTime?    @map("responded_at")
  attendance   Attendance[]
  event        Event        @relation(fields: [eventId], references: [id])
  inviter      User         @relation("InviterUser", fields: [invitedBy], references: [id])
  user         User?        @relation("InvitedUser", fields: [userId], references: [id])

  @@unique([eventId, invitedEmail])
  @@map("event_invites")
}

model Speaker {
  id              String            @id @default(uuid()) @db.Uuid
  fullName        String            @map("full_name") @db.VarChar
  bio             String?
  profileImage    String?           @map("profile_image") @db.VarChar
  organization    String?           @db.VarChar
  sessionSpeakers SessionSpeakers[]

  @@map("speakers")
}

model SessionSpeakers {
  id        String        @id @default(uuid()) @db.Uuid
  sessionId String        @map("session_id") @db.Uuid
  speakerId String        @map("speaker_id") @db.Uuid
  session   EventSessions @relation(fields: [sessionId], references: [id])
  speaker   Speaker       @relation(fields: [speakerId], references: [id])

  @@map("session_speakers")
}

model SessionMedia {
  id        String        @id @default(uuid()) @db.Uuid
  sessionId String        @map("session_id") @db.Uuid
  fileUrl   String        @map("file_url") @db.VarChar
  mediaType String        @map("media_type") @db.VarChar
  session   EventSessions @relation(fields: [sessionId], references: [id])

  @@map("session_media")
}

model RegistrationStatus {
  id            String         @id @default(uuid()) @db.Uuid
  name          String         @unique @db.VarChar
  registrations Registration[]

  @@map("registration_status")
}

model FormFields {
  id         String          @id @default(uuid()) @db.Uuid
  eventId    String          @map("event_id") @db.Uuid
  fieldLabel String          @map("field_label") @db.VarChar
  fieldType  String          @map("field_type") @db.VarChar
  isRequired Boolean         @map("is_required")
  event      Event           @relation(fields: [eventId], references: [id])
  responses  FormResponses[]

  @@map("form_fields")
}

model FormResponses {
  id             String       @id @default(uuid()) @db.Uuid
  registrationId String       @map("registration_id") @db.Uuid
  fieldId        String       @map("field_id") @db.Uuid
  value          String
  field          FormFields   @relation(fields: [fieldId], references: [id])
  registration   Registration @relation(fields: [registrationId], references: [id])

  @@map("form_responses")
}

model Hackathons {
  id                 String   @id @default(uuid()) @db.Uuid
  eventId            String   @map("event_id") @db.Uuid
  teamSizeMin        Int      @map("team_size_min")
  teamSizeMax        Int      @map("team_size_max")
  submissionDeadline DateTime @map("submission_deadline")
  judgingCriteria    String?  @map("judging_criteria")
  event              Event    @relation(fields: [eventId], references: [id])

  @@map("hackathons")
}

model Teams {
  id          String        @id @default(uuid()) @db.Uuid
  eventId     String        @map("event_id") @db.Uuid
  name        String        @db.VarChar
  leaderId    String        @map("leader_id") @db.Uuid
  submissions Submissions[]
  members     TeamMembers[]
  event       Event         @relation(fields: [eventId], references: [id])
  leader      User          @relation(fields: [leaderId], references: [id])

  @@map("teams")
}

model TeamMembers {
  id     String @id @default(uuid()) @db.Uuid
  teamId String @map("team_id") @db.Uuid
  userId String @map("user_id") @db.Uuid
  team   Teams  @relation(fields: [teamId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@map("team_members")
}

model Submissions {
  id           String   @id @default(uuid()) @db.Uuid
  teamId       String   @map("team_id") @db.Uuid
  projectTitle String   @map("project_title") @db.VarChar
  description  String?
  repoUrl      String?  @map("repo_url") @db.VarChar
  demoUrl      String?  @map("demo_url") @db.VarChar
  submittedAt  DateTime @default(now()) @map("submitted_at")
  scores       Scores[]
  team         Teams    @relation(fields: [teamId], references: [id])

  @@map("submissions")
}

model Judges {
  id      String   @id @default(uuid()) @db.Uuid
  userId  String   @map("user_id") @db.Uuid
  eventId String   @map("event_id") @db.Uuid
  event   Event    @relation(fields: [eventId], references: [id])
  user    User     @relation(fields: [userId], references: [id])
  scores  Scores[]

  @@map("judges")
}

model Scores {
  id           String      @id @default(uuid()) @db.Uuid
  submissionId String      @map("submission_id") @db.Uuid
  judgeId      String      @map("judge_id") @db.Uuid
  score        Int
  feedback     String?
  judge        Judges      @relation(fields: [judgeId], references: [id])
  submission   Submissions @relation(fields: [submissionId], references: [id])

  @@map("scores")
}

model SupportTicket {
  id          String           @id @default(uuid()) @db.Uuid
  userId      String           @map("user_id") @db.Uuid
  subject     String           @db.VarChar
  description String?
  category    TicketCategory
  priority    TicketPriority
  status      TicketStatus     @default(OPEN)
  targetRole  String?          @map("target_role") @db.VarChar
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  messages    SupportMessage[]
  user        User             @relation(fields: [userId], references: [id])

  @@map("support_tickets")
}

model SupportMessage {
  id        String        @id @default(uuid()) @db.Uuid
  ticketId  String        @map("ticket_id") @db.Uuid
  userId    String        @map("user_id") @db.Uuid
  message   String
  createdAt DateTime      @default(now()) @map("created_at")
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id])

  @@map("support_messages")
}

enum TicketCategory {
  TECHNICAL
  ACCOUNT
  EVENT_ISSUE
  EMERGENCY
  OTHER
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum OneTimeTokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}
