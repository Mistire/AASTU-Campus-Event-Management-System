generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum OneTimeTokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

model Role {
  id          String           @id @default(uuid()) @db.Uuid
  roleName    String           @unique @map("role_name") @db.VarChar
  description String?          @db.Text
  createdAt   DateTime         @default(now()) @map("created_at")
  users       User[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String           @id @default(uuid()) @db.Uuid
  name        String           @unique @db.VarChar
  description String?          @db.Text
  createdAt   DateTime         @default(now()) @map("created_at")
  roles       RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           String   @id @default(uuid()) @db.Uuid
  roleId       String   @map("role_id") @db.Uuid
  permissionId String   @map("permission_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model User {
  id              String   @id @default(uuid()) @db.Uuid
  fullName        String   @map("full_name") @db.VarChar
  email           String   @unique @db.VarChar
  passwordHash    String   @map("password_hash") @db.VarChar
  studentId       String?  @unique @map("student_id") @db.VarChar
  academicProgram String?  @map("academic_program") @db.VarChar
  roleId          String   @map("role_id") @db.Uuid
  departmentId    String?  @map("department_id") @db.Uuid
  phone           String?  @db.VarChar
  profileImage    String?  @map("profile_image") @db.VarChar
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  isEmailVerified    Boolean   @default(false) @map("is_email_verified")
  emailVerifiedAt    DateTime? @map("email_verified_at")
  isCampusIdVerified Boolean   @default(false) @map("is_campus_id_verified")
  campusIdVerifiedAt DateTime? @map("campus_id_verified_at")
  passwordChangedAt  DateTime? @map("password_changed_at")

  role                Role                      @relation(fields: [roleId], references: [id])
  createdEvents       Event[]                   @relation("EventCreator")
  department          Department?               @relation(fields: [departmentId], references: [id])
  receivedInvites     EventInvites[]             @relation("InvitedUser")
  sentInvites         EventInvites[]             @relation("InviterUser")
  ledTeams            Teams[]
  teamMembers         TeamMembers[]
  judgedEvents        Judges[]
  notifications       Notification[]
  registrations       Registration[]
  attendance          Attendance[]
  feedback            Feedback[]
  userInterests       UserInterests[]
  categoryPreferences UserCategoryPreferences[]
  eventOrganizers     EventOrganizers[]
  eventWaitlist       EventWaitlist[]
  auditLogs           AuditLogs[]
  announcements       Announcements[]

  authSessions  AuthSession[]
  oneTimeTokens OneTimeToken[]

  @@map("users")
}

model UserCategoryPreferences {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  categoryId String   @map("category_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")

  user     User     @relation(fields: [userId], references: [id])
  category Category @relation(fields: [categoryId], references: [id])

  @@unique([userId, categoryId])
  @@map("user_category_preferences")
}

model AuthSession {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  refreshTokenHash String    @map("refresh_token_hash") @db.VarChar
  userAgent        String?   @map("user_agent") @db.VarChar
  ipAddress        String?   @map("ip_address") @db.VarChar
  isRevoked        Boolean   @default(false) @map("is_revoked")
  expiresAt        DateTime  @map("expires_at")
  revokedAt        DateTime? @map("revoked_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId, isRevoked])
  @@index([expiresAt])
  @@map("auth_sessions")
}

model OneTimeToken {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  tokenHash String           @map("token_hash") @db.VarChar
  type      OneTimeTokenType
  expiresAt DateTime         @map("expires_at")
  usedAt    DateTime?        @map("used_at")
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId, type, usedAt])
  @@index([expiresAt])
  @@map("one_time_tokens")
}

model Department {
  id      String  @id @default(uuid()) @db.Uuid
  name    String  @db.VarChar
  faculty String? @db.VarChar
  users   User[]

  @@map("departments")
}

model EventStatus {
  id          String  @id @default(uuid()) @db.Uuid
  statusName  String  @unique @map("status_name") @db.VarChar
  description String? @db.Text
  events      Event[]

  @@map("event_status")
}

model Category {
  id              String                    @id @default(uuid()) @db.Uuid
  name            String                    @db.VarChar
  description     String?                   @db.Text
  eventCategories EventCategory[]
  userPreferences UserCategoryPreferences[]

  @@map("categories")
}

model EventCategory {
  eventId    String @map("event_id") @db.Uuid
  categoryId String @map("category_id") @db.Uuid

  event    Event    @relation(fields: [eventId], references: [id])
  category Category @relation(fields: [categoryId], references: [id])

  @@id([eventId, categoryId])
  @@map("event_categories")
}

model Interest {
  id            String          @id @default(uuid()) @db.Uuid
  name          String          @db.VarChar
  description   String?         @db.Text
  userInterests UserInterests[]

  @@map("interests")
}

model Tag {
  id        String      @id @default(uuid()) @db.Uuid
  name      String      @unique @db.VarChar
  eventTags EventTags[]

  @@map("tags")
}

model Venue {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar
  building    String?  @db.VarChar
  roomNumber  String?  @map("room_number") @db.VarChar
  capacity    Int?
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  events      Event[]

  @@unique([name, building, roomNumber])
  @@map("venues")
}

model Event {
  id               String   @id @default(uuid()) @db.Uuid
  title            String   @db.VarChar
  description      String?  @db.Text
  statusId         String   @map("status_id") @db.Uuid
  eventTypeId      String   @map("event_type_id") @db.Uuid
  venueId          String   @map("venue_id") @db.Uuid
  createdBy        String   @map("created_by") @db.Uuid
  startTime        DateTime @map("start_time")
  endTime          DateTime @map("end_time")
  capacity         Int
  requiresApproval Boolean  @default(false) @map("requires_approval")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  eventCategories EventCategory[]
  status          EventStatus       @relation(fields: [statusId], references: [id])
  eventType       EventType         @relation(fields: [eventTypeId], references: [id])
  venue           Venue             @relation(fields: [venueId], references: [id])
  creator         User              @relation("EventCreator", fields: [createdBy], references: [id])
  sessions        EventSessions[]
  organizers      EventOrganizers[]
  tags            EventTags[]
  media           EventMedia[]
  registrations   Registration[]
  attendance      Attendance[]
  feedback        Feedback[]
  waitlist        EventWaitlist[]
  announcements   Announcements[]
  access          EventAccess[]
  invites         EventInvites[]
  formFields      FormFields[]
  hackathons      Hackathons[]
  teams           Teams[]
  judges          Judges[]

  @@map("events")
}

model EventSessions {
  id          String   @id @default(uuid()) @db.Uuid
  eventId     String   @map("event_id") @db.Uuid
  title       String   @db.VarChar
  description String?  @db.Text
  sessionType String?  @map("session_type") @db.VarChar
  startTime   DateTime @map("start_time")
  endTime     DateTime @map("end_time")
  location    String?  @db.VarChar

  event      Event             @relation(fields: [eventId], references: [id])
  attendance Attendance[]
  speakers   SessionSpeakers[]
  media      SessionMedia[]

  @@map("event_sessions")
}

model EventOrganizers {
  id          String    @id @default(uuid()) @db.Uuid
  eventId     String    @map("event_id") @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  role        String?   @db.VarChar
  status      String    @default("ACCEPTED") @db.VarChar
  invitedAt   DateTime  @default(now()) @map("invited_at")
  respondedAt DateTime? @map("responded_at")

  event Event @relation(fields: [eventId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@unique([eventId, userId])
  @@map("event_organizers")
}

model AuditLogs {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  action     String   @db.VarChar
  entityType String   @map("entity_type") @db.VarChar
  entityId   String?  @map("entity_id") @db.Uuid
  details    String?  @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model Announcements {
  id        String   @id @default(uuid()) @db.Uuid
  eventId   String   @map("event_id") @db.Uuid
  title     String   @db.VarChar
  message   String   @db.Text
  createdBy String   @map("created_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  event   Event @relation(fields: [eventId], references: [id])
  creator User  @relation(fields: [createdBy], references: [id])

  @@map("announcements")
}

model EventWaitlist {
  id       String   @id @default(uuid()) @db.Uuid
  userId   String   @map("user_id") @db.Uuid
  eventId  String   @map("event_id") @db.Uuid
  joinedAt DateTime @default(now()) @map("joined_at")
  position Int

  user  User  @relation(fields: [userId], references: [id])
  event Event @relation(fields: [eventId], references: [id])

  @@map("event_waitlist")
}

model UserInterests {
  id         String @id @default(uuid()) @db.Uuid
  userId     String @map("user_id") @db.Uuid
  interestId String @map("interest_id") @db.Uuid

  user     User     @relation(fields: [userId], references: [id])
  interest Interest @relation(fields: [interestId], references: [id])

  @@map("user_interests")
}

model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  title     String   @db.VarChar
  message   String   @db.Text
  type      String   @db.VarChar
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("notifications")
}

model Registration {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  eventId          String    @map("event_id") @db.Uuid
  registrationDate DateTime  @default(now()) @map("registration_date")
  statusId         String    @map("status_id") @db.Uuid
  deletedAt        DateTime? @map("deleted_at")

  user   User               @relation(fields: [userId], references: [id])
  event  Event              @relation(fields: [eventId], references: [id])
  status RegistrationStatus @relation(fields: [statusId], references: [id])

  formResponses FormResponses[]

  @@map("registrations")
}

model Attendance {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  eventId     String   @map("event_id") @db.Uuid
  sessionId   String?  @map("session_id") @db.Uuid
  checkInTime DateTime @map("check_in_time")
  qrToken     String   @map("qr_token") @db.VarChar

  user    User           @relation(fields: [userId], references: [id])
  event   Event          @relation(fields: [eventId], references: [id])
  session EventSessions? @relation(fields: [sessionId], references: [id])

  @@map("attendance")
}

model Feedback {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  eventId   String   @map("event_id") @db.Uuid
  rating    Int
  comment   String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  user  User  @relation(fields: [userId], references: [id])
  event Event @relation(fields: [eventId], references: [id])

  @@map("feedback")
}

model EventMedia {
  id         String   @id @default(uuid()) @db.Uuid
  eventId    String   @map("event_id") @db.Uuid
  fileUrl    String   @map("file_url") @db.VarChar
  mediaType  String   @map("media_type") @db.VarChar
  uploadedAt DateTime @default(now()) @map("uploaded_at")

  event Event @relation(fields: [eventId], references: [id])

  @@map("event_media")
}

model EventTags {
  id      String @id @default(uuid()) @db.Uuid
  eventId String @map("event_id") @db.Uuid
  tagId   String @map("tag_id") @db.Uuid

  event Event @relation(fields: [eventId], references: [id])
  tag   Tag   @relation(fields: [tagId], references: [id])

  @@map("event_tags")
}

model EventType {
  id          String  @id @default(uuid()) @db.Uuid
  name        String  @unique @db.VarChar
  description String? @db.Text

  events Event[]

  @@map("event_types")
}

model EventAccess {
  id               String  @id @default(uuid()) @db.Uuid
  eventId          String  @map("event_id") @db.Uuid
  accessType       String  @map("access_type") @db.VarChar
  requiresApproval Boolean @map("requires_approval")

  event Event @relation(fields: [eventId], references: [id])

  @@map("event_access")
}

model EventInvites {
  id           String    @id @default(uuid()) @db.Uuid
  eventId      String    @map("event_id") @db.Uuid
  userId       String?   @map("user_id") @db.Uuid
  invitedEmail String    @map("invited_email") @db.VarChar
  invitedBy    String    @map("invited_by") @db.Uuid
  status       String    @default("PENDING") @db.VarChar
  createdAt    DateTime  @default(now()) @map("created_at")
  respondedAt  DateTime? @map("responded_at")

  event   Event @relation(fields: [eventId], references: [id])
  user    User? @relation("InvitedUser", fields: [userId], references: [id])
  inviter User  @relation("InviterUser", fields: [invitedBy], references: [id])

  @@unique([eventId, invitedEmail])
  @@map("event_invites")
}

model Speaker {
  id           String  @id @default(uuid()) @db.Uuid
  fullName     String  @map("full_name") @db.VarChar
  bio          String? @db.Text
  profileImage String? @map("profile_image") @db.VarChar
  organization String? @db.VarChar

  sessionSpeakers SessionSpeakers[]

  @@map("speakers")
}

model SessionSpeakers {
  id        String @id @default(uuid()) @db.Uuid
  sessionId String @map("session_id") @db.Uuid
  speakerId String @map("speaker_id") @db.Uuid

  session EventSessions @relation(fields: [sessionId], references: [id])
  speaker Speaker       @relation(fields: [speakerId], references: [id])

  @@map("session_speakers")
}

model SessionMedia {
  id        String @id @default(uuid()) @db.Uuid
  sessionId String @map("session_id") @db.Uuid
  fileUrl   String @map("file_url") @db.VarChar
  mediaType String @map("media_type") @db.VarChar

  session EventSessions @relation(fields: [sessionId], references: [id])

  @@map("session_media")
}

model RegistrationStatus {
  id   String @id @default(uuid()) @db.Uuid
  name String @db.VarChar

  registrations Registration[]

  @@map("registration_status")
}

model FormFields {
  id         String  @id @default(uuid()) @db.Uuid
  eventId    String  @map("event_id") @db.Uuid
  fieldLabel String  @map("field_label") @db.VarChar
  fieldType  String  @map("field_type") @db.VarChar
  isRequired Boolean @map("is_required")

  event     Event           @relation(fields: [eventId], references: [id])
  responses FormResponses[]

  @@map("form_fields")
}

model FormResponses {
  id             String @id @default(uuid()) @db.Uuid
  registrationId String @map("registration_id") @db.Uuid
  fieldId        String @map("field_id") @db.Uuid
  value          String @db.Text

  registration Registration @relation(fields: [registrationId], references: [id])
  field        FormFields   @relation(fields: [fieldId], references: [id])

  @@map("form_responses")
}

model Hackathons {
  id                 String   @id @default(uuid()) @db.Uuid
  eventId            String   @map("event_id") @db.Uuid
  teamSizeMin        Int      @map("team_size_min")
  teamSizeMax        Int      @map("team_size_max")
  submissionDeadline DateTime @map("submission_deadline")
  judgingCriteria    String?  @map("judging_criteria") @db.Text

  event Event @relation(fields: [eventId], references: [id])

  @@map("hackathons")
}

model Teams {
  id       String @id @default(uuid()) @db.Uuid
  eventId  String @map("event_id") @db.Uuid
  name     String @db.VarChar
  leaderId String @map("leader_id") @db.Uuid

  event       Event         @relation(fields: [eventId], references: [id])
  leader      User          @relation(fields: [leaderId], references: [id])
  members     TeamMembers[]
  submissions Submissions[]

  @@map("teams")
}

model TeamMembers {
  id     String @id @default(uuid()) @db.Uuid
  teamId String @map("team_id") @db.Uuid
  userId String @map("user_id") @db.Uuid

  team Teams @relation(fields: [teamId], references: [id])
  user User  @relation(fields: [userId], references: [id])

  @@map("team_members")
}

model Submissions {
  id           String   @id @default(uuid()) @db.Uuid
  teamId       String   @map("team_id") @db.Uuid
  projectTitle String   @map("project_title") @db.VarChar
  description  String?  @db.Text
  repoUrl      String?  @map("repo_url") @db.VarChar
  demoUrl      String?  @map("demo_url") @db.VarChar
  submittedAt  DateTime @default(now()) @map("submitted_at")

  team   Teams    @relation(fields: [teamId], references: [id])
  scores Scores[]

  @@map("submissions")
}

model Judges {
  id      String @id @default(uuid()) @db.Uuid
  userId  String @map("user_id") @db.Uuid
  eventId String @map("event_id") @db.Uuid

  user   User     @relation(fields: [userId], references: [id])
  event  Event    @relation(fields: [eventId], references: [id])
  scores Scores[]

  @@map("judges")
}

model Scores {
  id           String  @id @default(uuid()) @db.Uuid
  submissionId String  @map("submission_id") @db.Uuid
  judgeId      String  @map("judge_id") @db.Uuid
  score        Int
  feedback     String? @db.Text

  submission Submissions @relation(fields: [submissionId], references: [id])
  judge      Judges      @relation(fields: [judgeId], references: [id])

  @@map("scores")
}
