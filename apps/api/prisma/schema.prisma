generator client {
  provider = "prisma-client"
  output     = "../src/generated/prisma"
  moduleFormat = "cjs"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

model Role {
  id          String           @id @default(uuid()) @db.Uuid
  roleName    String   @map("role_name") @db.VarChar
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  users       User[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String           @id @default(uuid()) @db.Uuid
  name        String           @unique @db.VarChar
  description String?          @db.Text
  createdAt   DateTime         @default(now()) @map("created_at")
  roles       RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(uuid()) @db.Uuid
  roleId       String     @map("role_id") @db.Uuid
  permissionId String     @map("permission_id") @db.Uuid
  createdAt    DateTime   @default(now()) @map("created_at")

  role         Role       @relation(fields: [roleId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model User {
  id               String            @id @default(uuid()) @db.Uuid
  fullName         String            @map("full_name") @db.VarChar
  email            String            @unique @db.VarChar
  passwordHash     String            @map("password_hash") @db.VarChar
  roleId           String            @map("role_id") @db.Uuid
  departmentId     String?           @map("department_id") @db.Uuid
  phone            String?           @db.VarChar
  profileImage     String?           @map("profile_image") @db.VarChar
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  
  role             Role              @relation(fields: [roleId], references: [id])
  department       Department?       @relation(fields: [departmentId], references: [id])
  notifications    Notification[]
  registrations    Registration[]
  attendance       Attendance[]
  feedback         Feedback[]
  userInterests    UserInterests[]
  eventOrganizers  EventOrganizers[]
  eventWaitlist    EventWaitlist[]
  auditLogs        AuditLogs[]

  @@map("users")
}

model Department {
  id      String   @id @default(uuid()) @db.Uuid
  name    String   @db.VarChar
  faculty String?  @db.VarChar
  users   User[]

  @@map("departments")
}

model EventStatus {
  id          String   @id @default(uuid()) @db.Uuid
  statusName  String   @map("status_name") @db.VarChar
  description String?  @db.Text
  events      Event[]

  @@map("event_status")
}

model Category {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar
  description String?  @db.Text
  events      Event[]

  @@map("categories")
}

model Interest {
  id            String          @id @default(uuid()) @db.Uuid
  name          String          @db.VarChar
  description   String?         @db.Text
  userInterests UserInterests[]

  @@map("interests")
}

model Tag {
  id        String     @id @default(uuid()) @db.Uuid
  name      String     @db.VarChar
  eventTags EventTags[]

  @@map("tags")
}

model Venue {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar
  building    String?  @db.VarChar
  roomNumber  String?  @map("room_number") @db.VarChar
  capacity    Int?
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  events      Event[]

  @@map("venues")
}

model Event {
  id               String            @id @default(uuid()) @db.Uuid
  title            String            @db.VarChar
  description      String?           @db.Text
  categoryId       String            @map("category_id") @db.Uuid
  statusId         String            @map("status_id") @db.Uuid
  venueId          String            @map("venue_id") @db.Uuid
  startTime        DateTime          @map("start_time")
  endTime          DateTime          @map("end_time")
  capacity         Int
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  category         Category          @relation(fields: [categoryId], references: [id])
  status           EventStatus       @relation(fields: [statusId], references: [id])
  venue            Venue             @relation(fields: [venueId], references: [id])
  sessions         EventSessions[]
  organizers       EventOrganizers[]
  tags             EventTags[]
  media            EventMedia[]
  registrations    Registration[]
  attendance       Attendance[]
  feedback         Feedback[]
  waitlist         EventWaitlist[]
  announcements    Announcements[]

  @@map("events")
}

model EventSessions {
  id        String   @id @default(uuid()) @db.Uuid
  eventId   String   @map("event_id") @db.Uuid
  title     String   @db.VarChar
  startTime DateTime @map("start_time")
  endTime   DateTime @map("end_time")
  
  event     Event    @relation(fields: [eventId], references: [id])
  attendance Attendance[]

  @@map("event_sessions")
}

model EventOrganizers {
  id      String  @id @default(uuid()) @db.Uuid
  eventId String  @map("event_id") @db.Uuid
  userId  String  @map("user_id") @db.Uuid
  role    String? @db.VarChar

  event   Event   @relation(fields: [eventId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@map("event_organizers")
}

model AuditLogs {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  action     String   @db.VarChar
  entityType String   @map("entity_type") @db.VarChar
  entityId   String?  @map("entity_id") @db.Uuid
  details    String?  @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  user       User     @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model Announcements {
  id        String   @id @default(uuid()) @db.Uuid
  eventId   String   @map("event_id") @db.Uuid
  title     String   @db.VarChar
  message   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  event     Event    @relation(fields: [eventId], references: [id])

  @@map("announcements")
}

model EventWaitlist {
  id       String   @id @default(uuid()) @db.Uuid
  userId   String   @map("user_id") @db.Uuid
  eventId  String   @map("event_id") @db.Uuid
  joinedAt DateTime @default(now()) @map("joined_at")
  position Int

  user     User     @relation(fields: [userId], references: [id])
  event    Event    @relation(fields: [eventId], references: [id])

  @@map("event_waitlist")
}

model UserInterests {
  id         String @id @default(uuid()) @db.Uuid
  userId     String @map("user_id") @db.Uuid
  interestId String @map("interest_id") @db.Uuid

  user       User     @relation(fields: [userId], references: [id])
  interest   Interest @relation(fields: [interestId], references: [id])

  @@map("user_interests")
}

model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  title     String   @db.VarChar
  message   String   @db.Text
  type      String   @db.VarChar
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id])

  @@map("notifications")
}

model Registration {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @map("user_id") @db.Uuid
  eventId          String   @map("event_id") @db.Uuid
  registrationDate DateTime @default(now()) @map("registration_date")
  status           String   @db.VarChar

  user             User     @relation(fields: [userId], references: [id])
  event            Event    @relation(fields: [eventId], references: [id])

  @@map("registrations")
}

model Attendance {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  eventId     String   @map("event_id") @db.Uuid
  sessionId   String?  @map("session_id") @db.Uuid
  checkInTime DateTime @map("check_in_time")
  qrToken     String   @map("qr_token") @db.VarChar

  user        User     @relation(fields: [userId], references: [id])
  event       Event    @relation(fields: [eventId], references: [id])
  session     EventSessions? @relation(fields: [sessionId], references: [id])

  @@map("attendance")
}

model Feedback {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  eventId   String   @map("event_id") @db.Uuid
  rating    Int
  comment   String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id])
  event     Event    @relation(fields: [eventId], references: [id])

  @@map("feedback")
}

model EventMedia {
  id         String   @id @default(uuid()) @db.Uuid
  eventId    String   @map("event_id") @db.Uuid
  fileUrl    String   @map("file_url") @db.VarChar
  mediaType  String   @map("media_type") @db.VarChar
  uploadedAt DateTime @default(now()) @map("uploaded_at")

  event      Event    @relation(fields: [eventId], references: [id])

  @@map("event_media")
}

model EventTags {
  id      String @id @default(uuid()) @db.Uuid
  eventId String @map("event_id") @db.Uuid
  tagId   String @map("tag_id") @db.Uuid

  event   Event @relation(fields: [eventId], references: [id])
  tag     Tag   @relation(fields: [tagId], references: [id])

  @@map("event_tags")
}
